				VerticalSpacing = 0,
				SortOrder = Enum.SortOrder.Name,
				LayoutOrder = 0,
			} :: ScrollContainer.ScrollContainerProps,
			children
		),
	})
end

return function(props: RoomListProps)
	if props.Visible == false then
		return nil
	end

	return RoomList(props)
end
