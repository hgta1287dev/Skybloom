<file path="src/core/LoggerManager/init.luau">
local RunService = game:GetService("RunService")
local Logger = require(script.Logger)

local LoggerManager = {}
LoggerManager.__index = LoggerManager

-- * Types
export type LogLevelName = "Debug" | "Info" | "Warn" | "Error"
export type LogLevel = number
export type Handler = (level: LogLevel, message: string) -> ()

-- * Constants
local IS_SERVER = RunService:IsServer()
local SIDE_PREFIX = IS_SERVER and "SERVER" or "CLIENT"

local LogLevels = {
	Debug = 1,
	Info = 2,
	Warn = 3,
	Error = 4,
}

-- * Constructor
function LoggerManager.new()
	local self = setmetatable({}, LoggerManager)

	self._started = false
	self._enabled = true
	self._level = LogLevels.Info
	self._handlers = {}
	self._buffer = {}

	-- default console handler
	self:AddHandler(function(level, message)
		if level == LogLevels.Warn then
			warn(message)
		elseif level == LogLevels.Error then
			error(message, 2)
		else
			print(message)
		end
	end)

	return self
end

-- * Private
function LoggerManager:_shouldLog(level: LogLevel)
	return self._enabled and level >= self._level
end

function LoggerManager:_dispatch(level: LogLevel, message: string)
	if not self:_shouldLog(level) then
		return
	end

	if not self._started then
		table.insert(self._buffer, { level = level, message = message })
		return
	end

	for _, handler in ipairs(self._handlers) do
		handler(level, message)
	end
end

-- * Public
function LoggerManager:SetLevel(levelName: LogLevelName)
	local level = LogLevels[levelName]
	if level then
		self._level = level
	end
end

function LoggerManager:Enable(state: boolean)
	self._enabled = state
end

function LoggerManager:AddHandler(handler: Handler)
	table.insert(self._handlers, handler)
end

function LoggerManager:Init()
	if self._started then
		return
	end

	self._started = true

	for _, entry in ipairs(self._buffer) do
		if self:_shouldLog(entry.level) then
			for _, handler in ipairs(self._handlers) do
				handler(entry.level, entry.message)
			end
		end
	end

	table.clear(self._buffer)
end

-- Logger Factory
function LoggerManager:CreateLogger(scope: string?)
	return Logger.new(self, SIDE_PREFIX, scope, LogLevels)
end

return LoggerManager.new()
</file>

<file path="src/core/LoggerManager/Logger.luau">
local Logger = {}
Logger.__index = Logger

--* Types
export type LogLevel = number

--* Constructor
function Logger.new(manager: any, sidePrefix: string, scope: string?, logLevels: { [string]: number })
	return setmetatable({
		_scope = scope,
		_manager = manager,
		_prefix = sidePrefix,
		_levels = logLevels,
	}, Logger)
end

--* Private
function Logger:_format(...)
	local header

	if self._scope and self._scope ~= "" then
		header = string.format("[%s][%s]: ", self._prefix, self._scope)
	else
		header = string.format("[%s]: ", self._prefix)
	end

	local parts = table.pack(...)
	for i = 1, parts.n do
		parts[i] = tostring(parts[i])
	end

	return header .. table.concat(parts, " ")
end

function Logger:_log(level: LogLevel, ...)
	local message = self:_format(...)
	self._manager:_dispatch(level, message)
	return message
end

--* Public
function Logger:Debug(...)
	return self:_log(self._levels.Debug, ...)
end

function Logger:Info(...)
	return self:_log(self._levels.Info, ...)
end

function Logger:Warn(...)
	return self:_log(self._levels.Warn, ...)
end

function Logger:Error(...)
	return self:_log(self._levels.Error, ...)
end

return Logger
</file>

