<file path="src/services/MapService/MapFactory.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local ServerStorage = game:GetService("ServerStorage")
local GameTypes = require(ReplicatedStorage.Shared.Types.GameTypes)
local Logger = require(ReplicatedStorage.Shared.Utils.Logger)
local MapContainer = require(script.Parent.MapContainer)

local MapFactory = {}

-- * Types
export type Mode = GameTypes.Mode

-- * ONLY SERVER * --
-- * Public
function MapFactory.GetMapTemplate(mode: Mode, mapName: string, timeout: number): (Instance?, string?)
	if not RunService:IsServer() then
		Logger.warn("MapFactory", "Cannot get map template on client")
		return nil, "Cannot get map template on client"
	end

	local assets = ServerStorage:WaitForChild("Assets", timeout)
	if not assets then
		return nil, "Assets folder not found!"
	end

	local mapsFolder = assets:WaitForChild("Maps", timeout)
	if not mapsFolder then
		return nil, "Maps folder not found!"
	end

	local modeFolder = mapsFolder and mapsFolder:WaitForChild(mode, timeout) :: Instance?
	if not modeFolder then
		return nil, `No maps found for mode "{mode}"`
	end

	local mapTemplate = modeFolder:WaitForChild(mapName, timeout) :: Instance?
	return mapTemplate, if mapTemplate then nil else `No map "{mapName}" in mode "{mode}"`
end

function MapFactory.ValidateMapTemplate(template: Instance): (boolean, string?)
	-- * Exists Validation
	if not template then
		return false, "Template is nil"
	end

	-- * Model Validation
	if not template:IsA("Model") then
		return false, `Map template "{template:GetFullName()}" must be a Model`
	end

	-- * Root Validation
	local root = template:FindFirstChild("Root")
	if not root then
		return false, `Map template "{template:GetFullName()}" must contain a BasePart named "Root"`
	end
	if not root:IsA("BasePart") then
		return false, `"Root" must be a BasePart`
	end
	if template.PrimaryPart ~= root then
		return false, `PrimaryPart of "{template:GetFullName()}" must be set to "Root"`
	end

	-- * CameraPivot Validation
	local cameraPivot = template:FindFirstChild("CameraPivot")
	if not cameraPivot then
		return false, `Map template "{template:GetFullName()}" must contain a BasePart named "CameraPivot"`
	elseif not cameraPivot:IsA("BasePart") then
		return false, `"CameraPivot" must be a BasePart: {template:GetFullName()}`
	end

	-- * Geometry Validation
	local geometry = template:FindFirstChild("Geometry")
	if not geometry then
		return false, `Map template "{template:GetFullName()}" must contain a Folder named "Geometry"`
	end
	for _, part in geometry:GetChildren() do
		if not part:IsA("BasePart") then
			return false, `Part "{part:GetFullName()}" must be a BasePart`
		end
	end

	-- * Props Validation
	local props = template:FindFirstChild("Props")
	if not props then
		return false, `Map template "{template:GetFullName()}" must contain a Folder named "Props"`
	end

	-- * Runtime Validation
	local runtime = template:FindFirstChild("Runtime")
	if not runtime then
		return false, `Map template "{template:GetFullName()}" must contain a Folder named "Runtime"`
	end

	-- * Interactables Validation
	local interactables = template:FindFirstChild("Interactables")
	if not interactables then
		return false, `Map template "{template:GetFullName()}" must contain a Folder named "Interactables"`
	end

	-- * Modules Validation
	local modules = template:FindFirstChild("Modules")
	if not modules then
		return false, `Map template "{template:GetFullName()}" must contain a Folder named "Modules"`
	end
	for _, moduleScript in modules:GetChildren() do
		if not moduleScript:IsA("ModuleScript") then
			return false, `Module "{moduleScript:GetFullName()}" must be a ModuleScript`
		end
	end
	return true
end

function MapFactory.CreateMap(mode: Mode, mapName: string, timeout: number): (Instance?, string?)
	if not RunService:IsServer() then
		Logger.warn("MapFactory", "Cannot create map on client")
		return nil, "Cannot create map on client"
	end

	-- Find map template
	local mapTemplate, err = MapFactory.GetMapTemplate(mode, mapName, timeout)
	if not mapTemplate then
		return nil, err
	end

	-- Validate map template
	local isMapValid, mapValidateErr = MapFactory.ValidateMapTemplate(mapTemplate)
	if not isMapValid then
		return nil, mapValidateErr
	end

	-- Create map
	local container = MapContainer.GetContainer()
	local map = mapTemplate:Clone()
	map.Parent = container

	return map
end

return MapFactory
</file>

<file path="src/services/MapService/MapModulesManager.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Logger = require(ReplicatedStorage.Shared.Utils.Logger)
local MapModulesManager = {}
MapModulesManager.__index = MapModulesManager

-- * Types
export type MapModulesManager = {
	_started: boolean,
	_destroyed: boolean,
	_map: Model,
	_modules: { [string]: any },
}

-- * Utils
local function ValidateAndRequire(moduleScript: ModuleScript): (boolean, any)
	local success, res = pcall(require, moduleScript)
	if not success then
		return false, res
	elseif typeof(res) ~= "table" then
		return false, `Module "{moduleScript.Name}" must return a table`
	elseif typeof(res.Init) ~= "function" then
		return false, `Module "{moduleScript.Name}" must have Init`
	elseif typeof(res.Start) ~= "function" then
		return false, `Module "{moduleScript.Name}" must have Start`
	elseif typeof(res.Destroy) ~= "function" then
		return false, `Module "{moduleScript.Name}" must have Destroy`
	end

	return true, res
end

local function run(callback)
	local ok, result = pcall(callback)
	if not ok then
		Logger.error("MapModulesManager", result)
	end
end

-- * Constructor
function MapModulesManager.new(map: Model)
	local self = setmetatable({}, MapModulesManager)
	self._started = false
	self._destroyed = false
	self._map = map
	self._modules = {}
	return self
end

-- * Public
function MapModulesManager:Register(moduleScript: ModuleScript): (boolean, any)
	-- Already registered
	if self._modules[moduleScript.Name] then
		return false, `Module "{moduleScript.Name}" is already registered`
	end

	-- Already started or destroyed
	if self._started or self._destroyed then
		return false, "MapModulesManager is already started or destroyed"
	end

	-- Validate
	local ok, result = ValidateAndRequire(moduleScript)
	if not ok then
		return false, result
	end

	-- Register
	self._modules[moduleScript.Name] = result
	return true
end

function MapModulesManager:RegisterAll(moduleScripts: { ModuleScript })
	for _, moduleScript in moduleScripts do
		self:Register(moduleScript)
	end
end

-- * Lifecycle
function MapModulesManager:Start()
	-- Already started or destroyed
	if self._started or self._destroyed then
		return
	end
	self._started = true

	-- Freeze modules
	table.freeze(self._modules)

	-- Run modules
	for _, module in pairs(self._modules) do
		run(function()
			module.Init(self._map)
		end)
	end
	for _, module in pairs(self._modules) do
		run(function()
			module.Start(self._map)
		end)
	end
end

function MapModulesManager:Destroy()
	-- Already destroyed
	if self._destroyed then
		return
	end
	self._destroyed = true

	-- Destroy modules
	for _, module in pairs(self._modules) do
		run(function()
			module.Destroy(self._map)
		end)
	end

	--! do not clear self._modules
end

return MapModulesManager
</file>

<file path="src/services/MapService/Server.luau">
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Knit = require(ReplicatedStorage.Packages.Knit)
local Signal = require(ReplicatedStorage.Packages.Signal)
local OrderedSet = require(ReplicatedStorage.Packages._Index["hgta1287dev_ordered-set@1.2.0"]["ordered-set"])
local KnitMessageConfig = require(ReplicatedStorage.Shared.Configs.KnitMessageConfig)
local MapContainer = require(ReplicatedStorage.Shared.Services.MapService.MapContainer)
local MapFactory = require(ReplicatedStorage.Shared.Services.MapService.MapFactory)
local MapModulesManager = require(ReplicatedStorage.Shared.Services.MapService.MapModulesManager)
local GameTypes = require(ReplicatedStorage.Shared.Types.GameTypes)
local LoggerManager = require(ReplicatedStorage.Shared.Core.LoggerManager)

local Logger = LoggerManager:CreateLogger("MapService")
local MapService = Knit.CreateService({
	Name = "MapService",

	Client = {
		MapUpdated = Knit.CreateSignal(),

		TransitionFinished = function(self, player, transitionId)
			self.Server:_onTransitionFinished(player, transitionId)
		end,

		GetCurrentMapAddress = function(self)
			local map = self.Server:GetCurrentMap()
			return map and map.Name, self.Server:GetCurrentTransitionId()
		end,
	},

	MapUpdated = Signal.new(),

	CurrentMap = nil :: Model?,
	_pendingMap = nil :: Model?,
	_currentModulesManager = nil :: any,
	_pendingModulesManager = nil :: any,

	_playersAtTransition = OrderedSet.new() :: OrderedSet.OrderedSet<Player>,
	_finishedPlayers = OrderedSet.new() :: OrderedSet.OrderedSet<Player>,

	_currentTransitionId = 0,
})

-- * Types
export type Mode = GameTypes.Mode
export type MapModulesManager = MapModulesManager.MapModulesManager

-- * Constants
local LOAD_MAP_TIMEOUT = 10
local TRANISTION_TIMEOUT = 30
local TRANISTION_FINISHED_DELAY = 5

-- * Private
function MapService:_destroyPending()
	if self._pendingModulesManager then
		self._pendingModulesManager:Destroy()
		self._pendingModulesManager = nil
	end

	if self._pendingMap then
		self._pendingMap:Destroy()
		self._pendingMap = nil
	end
end

function MapService:_completeTransition(transitionId)
	if transitionId ~= self._currentTransitionId then
		return
	end

	task.delay(TRANISTION_FINISHED_DELAY, function()
		if transitionId ~= self._currentTransitionId then
			return
		end

		self:_destroyPending()
	end)
end

function MapService:_onTransitionFinished(player: Player, transitionId: number)
	if transitionId ~= self._currentTransitionId then
		return
	end

	if not self._playersAtTransition:Has(player) then
		return
	end

	if self._finishedPlayers:PushBack(player) then
		if self._finishedPlayers:Size() >= self._playersAtTransition:Size() then
			self:_completeTransition(transitionId)
		end
	end
end

-- * Public
function MapService:CreateMap(mode: Mode, mapName: string, timeout: number?)
	self:_destroyPending()

	self._currentTransitionId += 1
	local transitionId = self._currentTransitionId

	-- Reset state
	self._playersAtTransition:Clear()
	self._finishedPlayers:Clear()

	-- Snapshot current players
	for _, player in Players:GetPlayers() do
		self._playersAtTransition:PushBack(player)
	end

	-- Load map
	local oldMap = self.CurrentMap
	local newMap, err = MapFactory.CreateMap(mode :: Mode, mapName, timeout or LOAD_MAP_TIMEOUT)

	if not newMap then
		Logger:Error(err)
		return
	end

	self.CurrentMap = newMap
	self._pendingMap = oldMap

	-- Load modules
	local oldModulesManager = self._currentModulesManager
	local newModulesManager = MapModulesManager.new(newMap)
	newModulesManager:RegisterAll((newMap.Modules :: Folder):GetChildren())

	self._pendingModulesManager = oldModulesManager
	self._currentModulesManager = newModulesManager

	-- start modules
	if self._currentModulesManager then
		self._currentModulesManager:Start()
	end

	-- Fire map updated
	self.MapUpdated:Fire(mapName, transitionId)
	self.Client.MapUpdated:FireAll(mapName, transitionId)

	-- Timeout fallback
	task.delay(TRANISTION_TIMEOUT, function()
		if transitionId == self._currentTransitionId then
			Logger:Warn(`Transition timeout. Forcing complete.`)
			self:_completeTransition(transitionId)
		end
	end)

	-- If no players at all
	if self._playersAtTransition:Empty() then
		self:_completeTransition(transitionId)
	end
end

function MapService:GetCurrentMap(): Instance?
	return self.CurrentMap
end

function MapService:GetCurrentTransitionId(): number
	return self._currentTransitionId
end

-- * Knit
function MapService:KnitInit()
	Logger:Info(KnitMessageConfig.Initializing)
	MapContainer.CreateContainer()
	Logger:Info(KnitMessageConfig.Initialized)
end

function MapService:KnitStart()
	Logger:Info(KnitMessageConfig.Starting)

	Players.PlayerRemoving:Connect(function(player)
		if self._playersAtTransition:Has(player) then
			self:_onTransitionFinished(player, self._currentTransitionId)
		end
	end)

	Logger:Info(KnitMessageConfig.Started)
end

return MapService
