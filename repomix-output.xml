<file path="src/ecs/Systems/Plants/GrowthSystem/Server.luau">
-- src/ecs/Systems/Plants/GrowthSystem/Server.luau
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ECS = require(ReplicatedStorage.Shared.Ecs.ECS)
local GrowthComponent = require(ReplicatedStorage.Shared.Ecs.Components.Plants.GrowthComponent)
local PlantNodeComponent = require(ReplicatedStorage.Shared.Ecs.Components.Plants.PlantNodeComponent)
local TransformComponent = require(ReplicatedStorage.Shared.Ecs.Components.TransformComponent)

local GROWTH_INTERVAL = 2

local function spawnBranches(world, parentId: number, cframe: CFrame, stage: number)
	local branchCount = if stage == 1 then 1 else if stage == 2 then 2 else 3
	local branchLength = math.max(0.4, 1.2 * (0.75 ^ stage))

	for i = 1, branchCount do
		world:spawn(
			PlantNodeComponent({
				parent = parentId,
				depth = stage,
				length = branchLength,
			}),
			TransformComponent({
				cframe = cframe,
			})
		)
	end
end

function System(world: ECS.World, state)
	local dt = state.deltaTime or 0.016

	for id, growth, transform in world:query(GrowthComponent, TransformComponent) do
		growth.timer += dt
		growth.age += dt

		if growth.timer < GROWTH_INTERVAL then
			continue
		end

		growth.timer -= GROWTH_INTERVAL

		if growth.stage >= growth.maxStage then
			continue
		end

		local nextStage = growth.stage + 1
		world:replace(
			id,
			growth:patch({
				stage = nextStage,
			})
		)

		-- Spawn branches if we haven't already for this stage
		if growth.lastSpawnStage < nextStage then
			growth.lastSpawnStage = nextStage
			spawnBranches(world, id, transform.cframe, nextStage)
		end
	end
end

return ECS.CreateSystem({
	name = "GrowthSystem",
	system = System,
})
