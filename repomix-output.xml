					child1Seen = true
				elseif child == child2 then
					child2Seen = true
				elseif child == child3 then
					child3Seen = true
				else
					error("Invalid child found")
				end
			end

			assert.equal(child1Seen, true)
			assert.equal(child2Seen, true)
			assert.equal(child3Seen, true)
		end)
	end)

