	tests["Passing tests pass: " .. child.Name] = function()
		check(child, true)
	end
end
for _, child in ipairs(failing:GetChildren()) do
	tests["Failing tests fail: " .. child.Name] = function()
		check(child, false)
	end
end
return tests
