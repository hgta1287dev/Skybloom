<file path="src/core/DevPanel/DevConsole/DevConsole.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LogSharedTypes = require(ReplicatedStorage.Shared.Core.LoggerManager.LogSharedTypes)

local IrisTypes = require(ReplicatedStorage.Packages._Index["sirmallard_iris@2.5.0"].iris.Types)
local OrderedCollections =
	require(ReplicatedStorage.Packages._Index["hgta1287dev_ordered-collections@1.0.0"]["ordered-collections"])
local DevFilterManager = require(ReplicatedStorage.Shared.Core.DevPanel.DevCommon.DevFilterManager)
local LoggerManager = require(ReplicatedStorage.Shared.Core.LoggerManager)

-- * Types
type Set<T> = OrderedCollections.Set<T>
type State<T> = IrisTypes.State<T>

type LogEntry = LogSharedTypes.LogEntry
type LogLevel = LogSharedTypes.LogLevel
type FilterManager = DevFilterManager.StateManager

-- * Constants
local MAX_LOGS = 300

-- * Constructor
local DevConsole = {
	levelFilterManager = DevFilterManager.new() :: FilterManager,
	categoryFilterManager = DevFilterManager.new() :: FilterManager,
	entries = OrderedCollections.Set.new() :: OrderedCollections.Set<LogEntry>,
}

-- * Private
-- Binding
function DevConsole:_onMessageOut(entry: LogEntry)
	self:Log(entry)
end

-- Update
function DevConsole:_addToEntries(entry: LogEntry)
	self.entries:PushFront(entry)
	if self.entries:Size() > MAX_LOGS then
		self.entries:PopBack()
	end
end

-- * Public
-- Pass through
function DevConsole:Filter(entry: LogEntry): boolean
	local levelState = self.levelFilterManager:GetState(entry.level)
	if not levelState or not levelState:get() then
		return false
	end

	local categoryState = self.categoryFilterManager:GetState(entry.category)
	if not categoryState or not categoryState:get() then
		return false
	end

	return true
end

-- Log Methods
function DevConsole:Log(entry: LogEntry)
	self:_addToEntries(entry)
end

function DevConsole:Clear()
	self.entries:Clear()
end

-- Getters
function DevConsole:GetEntriesSet(): Set<LogEntry>
	return self.entries
end

function DevConsole:EachEntry(callback: (entry: LogEntry) -> boolean?)
	self.entries:Each(callback)
end

-- Lifecycle
function DevConsole:Init()
	-- Bind MessageOut
	LoggerManager:ConnectMessageOut(function(message: string, entryBuffer: buffer)
		self:_onMessageOut(LoggerManager:DeserializeEntry(entryBuffer))
	end)
end

return DevConsole
</file>

<file path="src/core/DevPanel/DevConsole/DevConsolePanel.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DevConsole = require(script.Parent.DevConsole)
local DevConsoleStates = require(script.Parent.DevConsoleStates)
local Iris = require(ReplicatedStorage.Packages._Index["sirmallard_iris@2.5.0"].iris)
local IrisTypes = require(ReplicatedStorage.Packages._Index["sirmallard_iris@2.5.0"].iris.Types)
local DevPanelState = require(ReplicatedStorage.Shared.Core.DevPanel.DevCommon.DevPanelState)
local LogSharedTypes = require(ReplicatedStorage.Shared.Core.LoggerManager.LogSharedTypes)

local OutputConsole = {}
OutputConsole.__index = OutputConsole

-- * Types
type State<T> = IrisTypes.State<T>

export type LogLevel = LogSharedTypes.LogLevel
export type LogEntry = LogSharedTypes.LogEntry

-- * Default Config
local COLORS: { [LogLevel]: Color3 } = {
	Trace = Color3.fromRGB(75, 20, 255),
	Debug = Color3.fromRGB(100, 180, 255),
	Info = Color3.fromRGB(255, 255, 255),
	Warn = Color3.fromRGB(255, 160, 0),
	Error = Color3.fromRGB(255, 50, 50),
	Fatal = Color3.fromRGB(200, 0, 0),
}

-- * API
-- Render
function OutputConsole:Render()
	Iris.Window({ "Console Panel" }, { isOpened = DevPanelState.ShowConsolePanel })
	do
		Iris.SeparatorText({ "Options" })
		Iris.SameLine()
		do
			-- * Clear button
			if Iris.Button({ "Clear" }).clicked() then
				DevConsole:Clear()
			end
			-- * Search
		end
		Iris.End()

		-- * Options Field
		Iris.CollapsingHeader({ "Display Settings" })
		do
			Iris.Table({ 4 })
			do
				Iris.Checkbox({ "Show Date" }, { isChecked = DevConsoleStates.ShowDate })
				Iris.NextColumn()
				Iris.Checkbox({ "Show Run Side" }, { isChecked = DevConsoleStates.ShowRunSide })
				Iris.NextColumn()
				Iris.Checkbox({ "Show Run Scope" }, { isChecked = DevConsoleStates.ShowRunScope })
				Iris.NextColumn()
				Iris.Checkbox({ "Show Run Content" }, { isChecked = DevConsoleStates.ShowRunContent })
			end
			Iris.End()
		end
		Iris.End()

		-- * Categories Filter Field
		Iris.CollapsingHeader({ "Category filters" })
		do
			Iris.Table({ 4 })
			do
				-- * Filters "All"
				Iris.Checkbox({ "All" }, { isChecked = DevConsole.categoryFilterManager:GetMasterState() })

				-- * Other filters
				local cnt = 0
				DevConsole.categoryFilterManager:EachState(function(name: string, state: State<boolean>)
					cnt += 1
					if cnt % 2 == 0 then
						Iris.NextColumn()
					end
					Iris.Checkbox({ name }, { isChecked = state })
				end)
			end
			Iris.End()
		end
		Iris.End()

		-- * Level Filters Field
		Iris.CollapsingHeader({ "Level filters" })
		do
			Iris.Table({ 4 })
			do
				-- * Filters "All"
				Iris.Checkbox({ "All" }, { isChecked = DevConsole.levelFilterManager:GetMasterState() })

				-- * Other filters
				local cnt = 0
				DevConsole.levelFilterManager:EachState(function(name: string, state: State<boolean>)
					cnt += 1
					if cnt % 2 == 0 then
						Iris.NextColumn()
					end
					Iris.Checkbox({ name }, { isChecked = state })
				end)
			end
			Iris.End()
		end
		Iris.End()

		-- * Output Field
		Iris.SeparatorText({ "Output" })
		Iris.Indent()
		do
			DevConsole:EachEntry(function(entry: LogEntry)
				Iris.SameLine(5, nil, Enum.HorizontalAlignment.Left)
				do
					if DevConsoleStates.ShowDate:get() then
						Iris.Text({ entry._timestamp:format("0000.2f") })
						Iris.Separator()
					end

					if DevConsoleStates.ShowRunSide:get() then
						Iris.Text({ string.upper(entry._side) })
						Iris.Separator()
					end

					if DevConsoleStates.ShowRunScope:get() then
						Iris.Text({ entry.scope })
						Iris.Separator()
					end

					if DevConsoleStates.ShowRunContent:get() then
						Iris.TextColored({ entry.content, COLORS[entry.level] })
					end
				end
				Iris.End()
			end)
		end
		Iris.End()
	end
	Iris.End()
end

return OutputConsole
</file>

