<file path="src/services/CameraProxyService/Client.luau">
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local CameraProxyFactory = require(script.Parent.CameraProxyFactory)
local Knit = require(ReplicatedStorage.Packages.Knit)
local CframeBuffer = require(ReplicatedStorage.Shared.Utils.CframeBuffer)
local Logger = require(ReplicatedStorage.Shared.Utils.Logger)

local CameraProxyController = Knit.CreateController({
	Name = "CameraProxyController",

	_targets = {}, -- [userId] = target CFrame
	_cameras = {}, -- [userId] = Model
	_smoothing = 0.15, -- interpolation strength
})

-- * Constant
local SCOPENAME = "CameraProxyController"
local UPDATE_INTERVAL = 1 / 30 -- 30 hz
local RENDER_NAME = "CameraProxyController"
local RENDER_PRIORITY = Enum.RenderPriority.Last.Value

-- * Public
function CameraProxyController:CreateCamera(userId: number)
	if self._cameras[userId] then
		return self._cameras[userId]
	end

	local cameraModel = CameraProxyFactory:Create()
	self._cameras[userId] = cameraModel

	return cameraModel
end

function CameraProxyController:UpdateCameras(dt)
	for userId, target in pairs(self._targets) do
		local camera = self._cameras[userId]
		if camera then
			local current = camera:GetPivot()
			local alpha = 1 - math.exp(-dt * 12) -- framerate independent smoothing
			local new = current:Lerp(target, alpha)
			camera:PivotTo(new)
		end
	end
	table.clear(self._targets)
end

function CameraProxyController:GetCamera(userId: number)
	return self._cameras[userId]
end

-- * Private
function CameraProxyController:_onCamerasUpdated(snapshot)
	for userId, buffer in pairs(snapshot) do
		local cf = CframeBuffer.Deserialize(buffer)
		self._targets[userId] = cf
	end
end

function CameraProxyController:_onCameraAdded(userId: number)
	self:CreateCamera(userId)
end

function CameraProxyController:_onCameraRemoved(userId: number)
	local cam = self._cameras[userId]
	if cam then
		cam:Destroy()
	end

	self._cameras[userId] = nil
	self._targets[userId] = nil
end

function CameraProxyController:_renderStep(dt)
	self:UpdateCameras(dt)
end

-- Serialization
function CameraProxyController:_serializeCurrentCframe()
	local camera = workspace.CurrentCamera
	return CframeBuffer.Serialize(camera.CFrame)
end

-- My camera setup
function CameraProxyController:_setupMyCamera()
	local userId = game.Players.LocalPlayer.UserId
	local myCamera = self._cameras[userId]

	if not myCamera then
		return
	end

	for _, descendant in ipairs(myCamera:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.CanCollide = false
			descendant.CanTouch = false
			descendant.CanQuery = false
			descendant.Transparency = 1
		end
	end
end

-- * Knit
function CameraProxyController:KnitStart()
	local service = Knit.GetService("CameraProxyService")

	service
		:GetCameras()
		:andThen(function(res: { number })
			for _, userId in ipairs(res) do
				self:_onCameraAdded(userId)
			end
		end)
		:catch(function(err)
			Logger.error(SCOPENAME, err)
		end)

	service.CamerasUpdated:Connect(function(snapshot)
		self:_onCamerasUpdated(snapshot)
	end)

	service.CameraAdded:Connect(function(userId)
		self:_onCameraAdded(userId)
		if userId == game.Players.LocalPlayer.UserId then
			self:_setupMyCamera()
		end
	end)

	service.CameraRemoved:Connect(function(userId)
		self:_onCameraRemoved(userId)
	end)

	RunService:BindToRenderStep(RENDER_NAME, RENDER_PRIORITY, function(dt: number)
		self:_renderStep(dt)
		self._accumulator = self._accumulator and self._accumulator + dt or dt

		if self._accumulator < UPDATE_INTERVAL then
			return
		end

		local camera = workspace.CurrentCamera
		local currentCfr = camera.CFrame

		if currentCfr == self._lastCfr then
			return
		end

		self._accumulator = 0
		self._lastCfr = currentCfr

		local buffer = self:_serializeCurrentCframe()
		service:UpdateCamera(buffer):catch(function(err)
			Logger.error(SCOPENAME, err)
		end)
	end)
end

return CameraProxyController
</file>

<file path="src/services/CameraProxyService/Server.luau">
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Knit = require(ReplicatedStorage.Packages.Knit)
local OrderedCollections =
	require(ReplicatedStorage.Packages._Index["hgta1287dev_ordered-collections@1.0.0"]["ordered-collections"])
local CframeBuffer = require(ReplicatedStorage.Shared.Utils.CframeBuffer)
local Logger = require(ReplicatedStorage.Shared.Utils.Logger)

-- * Types
export type Map<K, V> = OrderedCollections.Map<K, V>
export type Set<T> = OrderedCollections.Set<T>

-- * Service
local CameraProxyService = Knit.CreateService({
	Name = "CameraProxyService",
	Client = {
		CameraAdded = Knit.CreateSignal(),
		CameraRemoved = Knit.CreateSignal(),
		CamerasUpdated = Knit.CreateSignal(),
	},
	cameras = OrderedCollections.Set.new() :: Set<number>,
	cframesBuffer = OrderedCollections.Map.new() :: Map<number, CFrame>,
})

-- * Constant
local SCOPENAME = "CameraProxyService"
local UPDATE_INTERVAL = 1 / 10 -- 1 / n = n hz

-- * Client API
function CameraProxyService.Client:GetCameras()
	local snapshot = self.Server:_serializeCameras()
	return snapshot
end

function CameraProxyService.Client:UpdateCamera(player: Player, cframeBuffer: buffer)
	local cameraCframe = CframeBuffer.Deserialize(cframeBuffer)
	CameraProxyService:UpdateCamera(player, cameraCframe)
end

-- * Public API
-- Cframe Updater
function CameraProxyService:UpdateCamera(player: Player, cameraCframe: CFrame)
	if typeof(cameraCframe) ~= "CFrame" then
		return
	end
	self.cframesBuffer:Set(player.UserId, cameraCframe)
end

function CameraProxyService:Render()
	if self.cframesBuffer:Size() == 0 then
		return
	end

	local snapshot = self:_serializeCframes()
	self.Client.CamerasUpdated:FireAll(snapshot)
end

-- Proxy Spawner
function CameraProxyService:Spawn(player: Player)
	if self.cameras:Has(player.UserId) then
		Logger.warn(SCOPENAME, "Camera already exists!")
	end

	self.cameras:PushBack(player.UserId)

	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer == player then
			continue
		end
		self.Client.CameraAdded:Fire(otherPlayer, player.UserId)
	end
end

function CameraProxyService:Despawn(player: Player)
	if not self.cameras:Has(player.UserId) then
		return
	end

	self.cameras:Pop(player.UserId)
	self.cframesBuffer:Remove(player.UserId)

	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer == player then
			continue
		end
		self.Client.CameraRemoved:Fire(otherPlayer, player.UserId)
	end
end

-- * Private API
function CameraProxyService:_serializeCameras(): { number }
	local set = self.cameras :: Set<number>
	return set:ToArray()
end

function CameraProxyService:_serializeCframes(): { [number]: CFrame }
	local map = self.cframesBuffer :: Map<number, CFrame>
	local packet = table.create(map:Size())

	map:Each(function(userId: number, cframe: CFrame)
		packet[userId] = CframeBuffer.Serialize(cframe)
	end)

	return packet
end

-- * Knit
function CameraProxyService:KnitStart()
	Players.PlayerAdded:Connect(function(player: Player)
		self:Spawn(player)
	end)
	Players.PlayerRemoving:Connect(function(player: Player)
		self:Despawn(player)
	end)
	RunService.Heartbeat:Connect(function(dt)
		self._accumulator = self._accumulator and self._accumulator + dt or dt
		if self._accumulator >= UPDATE_INTERVAL then
			self._accumulator = 0
			self:Render()
		end
	end)
end

return CameraProxyService
</file>

