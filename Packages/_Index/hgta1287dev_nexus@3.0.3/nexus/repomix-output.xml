--* Types
export type Node<T> = {
	value: T,
	prev: Node<T>?,
	next: Node<T>?,
}

export type NodeKey<K, V> = Node<V> & {
	key: K,
}

local Nodes = {}

function Nodes.new<K, V>(value: V, key: K?): Node<V> | NodeKey<K, V>
	if key ~= nil then
		return Nodes.keyValue(key, value)
	else
		return Nodes.value(value)
	end
end

function Nodes.value<T>(value: T): Node<T>
	return {
		value = value,
		prev = nil,
		next = nil,
	}
end

function Nodes.keyValue<K, V>(key: K, value: V): NodeKey<K, V>
	return {
		key = key,
		value = value,
		prev = nil,
		next = nil,
	}
end

return Nodes
</file>

<file path="lib/Utils/Iter.luau">
local Iter = {}
Iter.__index = Iter

type NextFn<T> = () -> T?
export type Iter<T> = {
	next: NextFn<T>,

	-- map: (self: Iter<T>, fn: (T) -> any) -> any, --! return Type<U> should using typeof
	-- filter: (self: Iter<T>, fn: (T) -> boolean) -> Iter<T>,
	-- take: (self: Iter<T>, n: number) -> Iter<T>,
	-- skip: (self: Iter<T>, n: number) -> Iter<T>,

	-- forEach: (self: Iter<T>, fn: (T) -> ()) -> (),
	-- toArray: (self: Iter<T>) -> { T },

	-- find: (self: Iter<T>, fn: (T) -> boolean) -> T?,
	-- some: (self: Iter<T>, fn: (T) -> boolean) -> boolean,
	-- every: (self: Iter<T>, fn: (T) -> boolean) -> boolean,
} & typeof(Iter)

-- * RAW
function Iter.fromArray<T>(arr: { T }): Iter<T>
	local i = 0
	return Iter.new(function()
		i += 1
		return arr[i]
	end)
end

function Iter.reduce<T, U>(self: Iter<T>, fn: (U, T) -> U, init: U): U
	local acc = init
	while true do
		local v = self.next()
		if v == nil then
			break
		end
		acc = fn(acc, v)
	end
	return acc
end

function Iter.fromLinked(head, reverse)
	local node = head

	return function()
		if not node then
			return nil
		end

		local current = node
		node = if reverse then current.prev else current.next

		return current
	end
end

function Iter.values<T>(head: any, reverse: boolean?): () -> T?
	local nextNode = Iter.fromLinked(head, reverse)

	return function()
		local node = nextNode()
		return node and node.value or nil
	end
end

function Iter.keyValues<K, V>(head: any, reverse: boolean?): () -> (K?, V?)
	local nextNode = Iter.fromLinked(head, reverse)

	return function()
		local node = nextNode()
		if not node then
			return nil, nil
		end
		return node.key, node.value
	end
end

-- * CONSTRUCTOR
function Iter.new<T>(nextFn: NextFn<T>): Iter<T>
	local self = setmetatable({
		next = nextFn,
	}, Iter)
	return self
end

-- * TRANSFORMS
function Iter.map<T, U>(self: Iter<T>, fn: (T) -> U): Iter<U>
	return Iter.new(function()
		local v = self.next()
		if v == nil then
			return nil
		end
		return fn(v)
	end)
end

function Iter.filter<T>(self: Iter<T>, fn: (T) -> boolean): Iter<T>
	return Iter.new(function()
		while true do
			local v = self.next()
			if v == nil then
				return nil
			end
			if fn(v) then
				return v
			end
		end
	end)
end

function Iter.take<T>(self: Iter<T>, n: number): Iter<T>
	local count = 0
	return Iter.new(function()
		if count >= n then
			return nil
		end
		local v = self.next()
		if v == nil then
			return nil
		end
		count += 1
		return v
	end)
end

function Iter.skip<T>(self: Iter<T>, n: number): Iter<T>
	local skipped = false
	return Iter.new(function()
		if not skipped then
			for _ = 1, n do
				if self.next() == nil then
					return nil
				end
			end
			skipped = true
		end
		return self.next()
	end)
end

-- * TERMINALS
function Iter.forEach<T>(self: Iter<T>, fn: (T) -> ())
	while true do
		local v = self.next()
		if v == nil then
			break
		end
		fn(v)
	end
end

function Iter.toArray<T>(self: Iter<T>): { T }
	local result = {}
	self:forEach(function(v)
		table.insert(result, v)
	end)
	return result
end

function Iter.find<T>(self: Iter<T>, fn: (T) -> boolean): T?
	while true do
		local v = self.next()
		if v == nil then
			return nil
		end
		if fn(v) then
			return v
		end
	end
end

function Iter.some<T>(self: Iter<T>, fn: (T) -> boolean): boolean
	return self:find(fn) ~= nil
end

function Iter.every<T>(self: Iter<T>, fn: (T) -> boolean)
	while true do
		local v = self.next()
		if v == nil then
			return true
		end
		if not fn(v) then
			return false
		end
	end
end

return Iter
</file>

<file path="lib/Collections/Set.luau">
local LinkedCollection = require(script.Parent.Parent.Core.LinkedCollection)
local Nodes = require(script.Parent.Parent.Core.Nodes)
local Iter = require(script.Parent.Parent.Utils.Iter)

local Set = {}
Set.__index = Set
setmetatable(Set, { __index = LinkedCollection })

type Node<T> = Nodes.Node<T>

export type Set<T> = {
	_map: { [T]: Node<T> },
	_head: Node<T>?,
	_tail: Node<T>?,

	PushFront: (self: Set<T>, value: T) -> boolean,
	PushBack: (self: Set<T>, value: T) -> boolean,

	Pop: (self: Set<T>, value: T) -> T?,
	PopFront: (self: Set<T>) -> T?,
	PopBack: (self: Set<T>) -> T?,

	Has: (self: Set<T>, value: T) -> boolean,
	Get: (self: Set<T>, value: T) -> T?,
	PeekFront: (self: Set<T>) -> T?,
	PeekBack: (self: Set<T>) -> T?,

	Values: (self: Set<T>, reverse: boolean?) -> () -> T?,
	Iter: (self: Set<T>, reverse: boolean?) -> Iter.Iter<T>,

	Clone: (self: Set<T>) -> Set<T>,
	ToArray: (self: Set<T>) -> { T },
	ToMap: (self: Set<T>) -> { [T]: boolean },
} & LinkedCollection.LinkedCollection

function Set.new<T>(): Set<T>
	local self = setmetatable(LinkedCollection.new(), Set)
	self._map = {}
	return self
end

function Set.fromArray<T>(arr: { T }): Set<T>
	local set = Set.new()
	for _, v in ipairs(arr) do
		set:PushBack(v)
	end
	return set
end

function Set.PushFront<T>(self: Set<T>, value: T): boolean
	assert(value ~= nil, "Set does not support nil values")

	if self._map[value] then
		return false
	end

	local node = {
		value = value,
		prev = nil,
		next = nil,
	}

	LinkedCollection._linkFront(self, node)
	self._map[value] = node
	self._size += 1

	return true
end

function Set.PushBack<T>(self: Set<T>, value: T): boolean
	assert(value ~= nil, "Set does not support nil values")

	if self._map[value] then
		return false
	end

	local node = {
		value = value,
		prev = nil,
		next = nil,
	}

	LinkedCollection._linkBack(self, node)
	self._map[value] = node
	self._size += 1

	return true
end

function Set.Pop<T>(self: Set<T>, value: T): T?
	local node = self._map[value]
	if not node then
		return nil
	end

	LinkedCollection._unlink(self, node)
	self._map[value] = nil
	self._size -= 1

	return node.value
end

function Set.PopFront<T>(self: Set<T>): T?
	local node = LinkedCollection._popFrontNode(self)
	if not node then
		return nil
	end

	self._map[node.value] = nil
	self._size -= 1

	return node.value
end

function Set.PopBack<T>(self: Set<T>): T?
	local node = LinkedCollection._popBackNode(self)
	if not node then
		return nil
	end

	self._map[node.value] = nil
	self._size -= 1
	return node.value
end

function Set.Has<T>(self: Set<T>, value: T): boolean
	return self._map[value] ~= nil
end

function Set.Get<T>(self: Set<T>, value: T): T?
	return self._map[value] and self._map[value].value or nil
end

function Set.PeekFront<T>(self: Set<T>): T?
	return self._head and self._head.value or nil
end

function Set.PeekBack<T>(self: Set<T>): T?
	return self._tail and self._tail.value or nil
end

function Set.Values<T>(self: Set<T>, reverse: boolean?): () -> T?
	return Iter.values(reverse and self._tail or self._head, reverse)
end

function Set.Iter<T>(self: Set<T>, reverse: boolean?): Iter.Iter<T>
	return Iter.new(Iter.values(reverse and self._tail or self._head, reverse))
end

function Set.Clear<T>(self: Set<T>)
	LinkedCollection.Clear(self)
	self._map = {}
end

function Set.ToArray<T>(self: Set<T>): { T }
	local arr = table.create(self:Size())
	local i = 0

	for v in self:Values() do
		i += 1
		arr[i] = v
	end

	return arr
end

function Set.ToMap<T>(self: Set<T>): { [T]: boolean }
	local map = {}

	for v in self:Values() do
		map[v] = true
	end

	return map
end

function Set.Clone<T>(self: Set<T>): Set<T>
	local newSet = Set.new()

	for v in self:Values() do
		newSet:PushBack(v)
	end

	return newSet
end

return Set
